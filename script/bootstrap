#!/bin/sh

set -e

LOG_FILE="bootstrap.log"
CURRENT_DIR=$(realpath $(dirname "${BASH_SOURCE[0]}"))
PARENT_DIR=$(dirname "$CURRENT_DIR")

source $PARENT_DIR/script/support/ansi
source $PARENT_DIR/script/support/helpers

ensure_sudo

show_loader "sleep 8"

# enable_touchid_sudo

exit 0


# Install Homebrew
if [ ! type "brew" > /dev/null 2>&1 ]; then
  cmd="/bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""
  show_loader "run $cmd" "Installing Homebrew..."
else
  show_loader "run brew update" "Updating System Dependencies..."
fi

# check disk encryption
if [ -z "$(fdesetup status | grep -E "FileVault is (On|Off, but will be enabled after the next restart).")" ]; then
  show_error "You need to enable disk encryption before you can continue."
  open "x-apple.systempreferences:com.apple.preference.security?FileVault"
  exit 1
fi

# Install XCode Command-Line Tools
echo "Checking Command Line Tools for Xcode"
# Only run if the tools are not installed yet
# To check that try to print the SDK path
xcode-select -p &> /dev/null
if [ $? -ne 0 ]; then
  echo "Command Line Tools for Xcode not found. Installing from softwareupdate…"
# This temporary file prompts the 'softwareupdate' utility to list the Command Line Tools
  touch /tmp/.com.apple.dt.CommandLineTools.installondemand.in-progress;
  PROD=$(softwareupdate -l | grep "\*.*Command Line" | tail -n 1 | sed 's/^[^C]* //')
  softwareupdate -i "$PROD" --verbose;
else
  echo "Command Line Tools for Xcode have been installed."
fi

# Install Homebrew Deps
if [ -f "Brewfile" ] && [ "$(uname -s)" = "Darwin" ]; then
  brew bundle check >/dev/null 2>&1  || {
    echo "==> Installing Homebrew dependencies…"
    brew bundle
  }
fi

# Install Chezmoi
brew install chezmoi
chezmoi init --apply brndnblck
