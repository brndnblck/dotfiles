#!/usr/bin/env bash

# Set strict error handling
set -euo pipefail

CURRENT_DIR=$(realpath $(dirname "${BASH_SOURCE[0]}"))
PARENT_DIR=$(dirname "$CURRENT_DIR")

# Source common helpers
source "$CURRENT_DIR/helpers/common"

update_development_tools() {
    show_header "Updating Development Tools to Latest Stable Versions"
    
    if ! check_command "asdf" "asdf version manager"; then
        log_error "asdf not found. Please install asdf first."
        exit 1
    fi
    
    # Update plugin repositories
    show_loader "asdf plugin update --all" "Updating asdf plugin repositories..."
    
    # Update each tool to latest stable
    for tool in ruby python nodejs golang; do
        log_info "Checking latest stable version for $tool..."
        
        local latest_version=$(silent "asdf latest $tool")
        
        if [ -n "$latest_version" ]; then
            local current_version=$(silent "asdf current $tool | awk '{print \$2}'" || echo "none")
            
            if [ "$current_version" = "$latest_version" ]; then
                log_success "$tool is already at latest stable version: $latest_version"
            else
                log_info "Upgrading $tool from $current_version to $latest_version..."
                show_loader "asdf install $tool $latest_version" "Installing $tool $latest_version..."
                silent "asdf global $tool $latest_version"
                log_success "$tool updated to $latest_version"
            fi
        else
            log_warn "Could not determine latest stable version for $tool"
        fi
    done
    
    show_header "Development tools update complete!" "green"
    
    log_info "Current versions:"
    for tool in ruby python nodejs golang; do
        local version=$(silent "asdf current $tool | awk '{print \$2}'" || echo "not installed")
        echo "  $tool: $version"
    done
    
    # Update cargo packages
    if check_command "cargo" "Cargo package manager"; then
        if check_file_exists "$PARENT_DIR/dependencies/cargo-packages" "cargo packages file"; then
            log_info "Updating cargo packages..."
            while IFS= read -r line || [ -n "$line" ]; do
                # Skip empty lines and comments
                [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
                
                # Extract package name (first word)
                package=$(echo "$line" | awk '{print $1}')
                
                if [ -n "$package" ]; then
                    log_info "Updating cargo package: $package"
                    silent "cargo install $package" || true
                fi
            done < "$PARENT_DIR/dependencies/cargo-packages"
        fi
    fi
    
    # Update npm packages
    if check_command "npm" "Node package manager"; then
        if check_file_exists "$PARENT_DIR/dependencies/npm-packages" "npm packages file"; then
            log_info "Updating npm packages..."
            while IFS= read -r line || [ -n "$line" ]; do
                # Skip empty lines and comments
                [[ -z "$line" || "$line" =~ ^[[:space:]]*# ]] && continue
                
                # Extract package name (first word)
                package=$(echo "$line" | awk '{print $1}')
                
                if [ -n "$package" ]; then
                    log_info "Updating npm package: $package"
                    silent "npm install -g $package@latest" || true
                fi
            done < "$PARENT_DIR/dependencies/npm-packages"
        fi
    fi
}

# Main execution
update_development_tools