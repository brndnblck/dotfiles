# Shows the username
[username]
format = '[//](bright-black bold) [$user](green) '
disabled = false
show_always = true

# Shows current directory
[directory]
truncation_length = 3
truncation_symbol = 'ÔÇĞ/'
home_symbol = '¾▒éÂ '
read_only = ' ¯Ö▓ '
format = '[//](bright-black bold) [$path]($style)[$read_only]($read_only_style) '
style = 'cyan'

# Shows current git branch
[git_branch]
symbol = '´Éİ '
format = '[//](bright-black bold) [$symbol\[$branch\]]($style)'
style = 'green'

# Shows current git status
[git_status]
disabled = true
format = '[ $all_status $ahead_behind]($style)'
style = 'green'
conflicted = '¾▒é┤'
up_to_date = ''
untracked = '¾░î© '
ahead = '¯¬á${count}'
diverged = '¯¬á¯¬Ø${ahead_count}Ôçú${behind_count}'
behind = '¯¬Ø${count}'
stashed = '´úû '
modified = '´üä '
staged = '[++\($count\)](bold cyan)'
renamed = '¾░æò '
deleted = '¯©ú '

# Shows kubernetes context and namespace
[kubernetes]
format = 'via [¾▒â¥ $context\($namespace\)](purple) '
disabled = false

