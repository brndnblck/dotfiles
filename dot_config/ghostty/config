# Ghostty Terminal Configuration
# https://ghostty.org/docs/config

# Appearance
theme = "cyber-dream"
font-family = "MesloLGS NF"
font-size = 14
font-thicken = true

# Window settings
window-decoration = true
window-title-font-family = "MesloLGS NF"
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
window-vsync = true

# Terminal behavior
cursor-style = "block"
cursor-style-blink = false
mouse-hide-while-typing = true
copy-on-select = false
confirm-close-surface = false

# Shell integration
shell-integration = "zsh"
shell-integration-features = "cursor,sudo,title"

# Performance
resize-overlay = "never"
resize-overlay-position = "center"
resize-overlay-duration = 0

# Keybindings (macOS style)
keybind = "cmd+t=new_tab"
keybind = "cmd+w=close_surface"
keybind = "cmd+shift+w=close_all_surfaces"
keybind = "cmd+n=new_window"
keybind = "cmd+shift+n=new_window"
keybind = "cmd+plus=increase_font_size:1"
keybind = "cmd+minus=decrease_font_size:1"
keybind = "cmd+zero=reset_font_size"
keybind = "cmd+c=copy_to_clipboard"
keybind = "cmd+v=paste_from_clipboard"
keybind = "cmd+shift+c=copy_to_clipboard"
keybind = "cmd+shift+v=paste_from_clipboard"

# Tab navigation
keybind = "cmd+1=goto_tab:1"
keybind = "cmd+2=goto_tab:2"
keybind = "cmd+3=goto_tab:3"
keybind = "cmd+4=goto_tab:4"
keybind = "cmd+5=goto_tab:5"
keybind = "cmd+6=goto_tab:6"
keybind = "cmd+7=goto_tab:7"
keybind = "cmd+8=goto_tab:8"
keybind = "cmd+9=goto_tab:9"
keybind = "cmd+shift+left=previous_tab"
keybind = "cmd+shift+right=next_tab"

# Split panes
keybind = "cmd+d=new_split:right"
keybind = "cmd+shift+d=new_split:down"
keybind = "cmd+shift+w=close_surface"
keybind = "cmd+shift+left=goto_split:previous"
keybind = "cmd+shift+right=goto_split:next"
keybind = "cmd+shift+up=goto_split:top"
keybind = "cmd+shift+down=goto_split:bottom"

# Search
keybind = "cmd+f=toggle_quick_terminal"

# Scrollback
scrollback-limit = 10000