#!/bin/bash

# homebrew and path hacking 
eval "$(/opt/homebrew/bin/brew shellenv)"
export PATH="$(brew --prefix coreutils)/libexec/gnubin:$PATH"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

# nvm
NVM_PATH=$(brew --prefix nvm)
export NVM_DIR="$HOME/.nvm"
  [ -s "$NVM_PATH/nvm.sh" ] && \. "$NVM_PATH/nvm.sh"  # This loads nvm
  [ -s "$NVM_PATH/etc/bash_completion.d/nvm" ] && \. "$NVM_PATH/etc/bash_completion.d/nvm"

# go
export PATH="$GOPATH/bin:$PATH"

# rbenv
eval "$(rbenv init -)"

# shell theme
source $(brew --prefix romkatv/powerlevel10k/powerlevel10k)/powerlevel10k.zsh-theme

# oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"
DISABLE_AUTO_UPDATE="true"
COMPLETION_WAITING_DOTS="true"
plugins=(git z docker npm sudo extract command-not-found colored-man-pages copybuffer golang python tmux)
source $ZSH/oh-my-zsh.sh

for file in ~/.{exports,aliases,functions,work}; do
  [ -r "$file" ] && source "$file"
done
unset file

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
