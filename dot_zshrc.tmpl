#!/bin/bash

export PATH="$(brew --prefix coreutils)/libexec/gnubin:$PATH"
export PATH="${KREW_ROOT:-$HOME/.krew}/bin:$PATH"

# nvm
export NVM_DIR="$HOME/.nvm"
. "$(brew --prefix nvm)/nvm.sh"

# go
export PATH="$GOPATH/bin:$PATH"

# rbenv
eval "$(rbenv init -)"

# ZSH (Oh-my-zsh)
ZSH=$HOME/.oh-my-zsh
ZSH_THEME="powerlevel9k/powerlevel9k"
DISABLE_AUTO_UPDATE="true"
COMPLETION_WAITING_DOTS="true"
plugins=(git z docker npm sudo zsh-autosuggestions zsh-syntax-highlighting extract command-not-found colored-man-pages copy-file copy-dir copybuffer golang python tmux)
source $ZSH/oh-my-zsh.sh

for file in ~/.{exports,aliases,functions,work}; do
  [ -r "$file" ] && source "$file"
done
unset file
